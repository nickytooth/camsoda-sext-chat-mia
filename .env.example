# xAI (Grok) — NSFW conversations + Vision
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-4.3

# Google (Gemini) — classification + summarization
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-3-flash-preview

# OpenAI — embeddings only
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Persona (single always-open persona)
SINGLE_PERSONA_FILE=personas/victoria2.yaml

# Database (PostgreSQL). The database itself must already exist; tables are
# created automatically on startup. Defaults to a local dev instance.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/victoria

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Default user ID (single-user demo)
DEFAULT_USER_ID=1
